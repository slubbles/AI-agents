# =============================================================
# Agent Brain — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- API Keys (Required: at least one) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here     # Optional: direct Anthropic (for PTC)

# --- Budget ---
DAILY_BUDGET_CLAUDE=2.00
DAILY_BUDGET_OPENROUTER=5.00
TOTAL_BALANCE_USD=10.00
# BALANCE_CLAUDE=0.00
# BALANCE_OPENROUTER=10.00

# --- Dashboard ---
DASHBOARD_API_KEY=your-dashboard-key-here
# DASHBOARD_CORS_ORIGINS=*

# --- Telegram Bot (Optional) ---
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# TELEGRAM_APPROVED_USERS=user1,user2

# --- Threads API (Optional) ---
# THREADS_ACCESS_TOKEN=your-threads-token

# --- Vercel Blob (Optional: image hosting for Threads) ---
# BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# --- Credential Vault ---
# VAULT_PASSPHRASE=your-vault-passphrase

# --- Programmatic Tool Calling (Optional: requires Anthropic credits) ---
# PTC_ENABLED=false

# --- VPS Deploy ---
# VPS_HOST=your-server-ip
# VPS_USER=root
# VPS_KEY_PATH=~/.ssh/id_rsa
